# Frontend env. Copy to `.env.local` for local overrides (gitignored).

# Where the Vite dev-server proxy forwards `/api/*`. Defaults to the local
# FastAPI dev server. (Build-time only; not used in the nginx prod image.)
VITE_PROXY_TARGET=http://127.0.0.1:8000

# Override the in-app API base. Leave unset to use the "/api" proxy (recommended);
# set to an absolute URL only for an unusual split-origin deploy.
# VITE_API_BASE=/api
