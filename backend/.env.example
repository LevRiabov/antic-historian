# Copy to .env and adjust. All settings: src/ahx/config.py (AHX_ prefix).
AHX_ENV=dev
AHX_DATABASE_URL=postgresql+psycopg://ahx:ahx@localhost:5433/ahx

# Embedding (gate D2, ADR-002): qwen3-embedding-8b via OpenRouter/Nebius.
# Defaults in config.py match the decision; only the key is needed here.
AHX_EMBED_API_KEY=sk-or-v1-...

# Judge LLM (generation-tier eval, `ahx eval generate --judge`).
# Any OpenAI-compatible endpoint; current pick: OpenRouter + DeepSeek V4 Flash.
AHX_JUDGE_BASE_URL=https://openrouter.ai/api/v1
AHX_JUDGE_MODEL=deepseek/deepseek-v4-flash
AHX_JUDGE_API_KEY=sk-or-v1-...

# Answer model / embeddings default to local llama-swap (see config.py); override
# here for hosted providers. NOTE for the Docker deploy: there is no local llama-swap
# inside the container, so the chat model MUST be hosted — set these three or /ask
# fails trying to reach 127.0.0.1:8080.
# AHX_CHAT_BASE_URL=https://openrouter.ai/api/v1
# AHX_CHAT_MODEL=deepseek/deepseek-v4-pro
# AHX_CHAT_API_KEY=sk-or-v1-...
# Answer output cap (default 2048) and the /ask SSE wall-clock ceiling in seconds
# (default 180):
# AHX_CHAT_MAX_TOKENS=2048
# AHX_REQUEST_TIMEOUT_SECONDS=180

# Trust X-Forwarded-For for per-IP rate limiting. The docker-compose nginx sets this
# for you; leave OFF for a bare local `ahx serve` (spoofable without a trusted proxy).
# AHX_TRUST_FORWARDED_FOR=1

# Langfuse tracing (Phase 6.1) — OPT-IN: set all three to enable, omit any to
# run untraced. Local self-hosted instance below; keys from the project's
# Settings -> API Keys page (pk-lf-... / sk-lf-...).
# AHX_LANGFUSE_HOST=http://localhost:3000
# AHX_LANGFUSE_PUBLIC_KEY=pk-lf-...
# AHX_LANGFUSE_SECRET_KEY=sk-lf-...
